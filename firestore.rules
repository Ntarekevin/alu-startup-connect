rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    /// Is the request from a signed-in user?
    function isAuth() {
      return request.auth != null;
    }

    /// Is the caller the document owner?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    /// Is the caller an admin (email domain @aluadmin.com)?
    function isAdmin() {
      return isAuth() && request.auth.token.email.matches('.*@aluadmin\\.com');
    }

    /// Is the caller an approved startup?
    function isApprovedStartup() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'startup' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    // ── users ─────────────────────────────────────────────────────────────────
    // • Anyone can create their own user document on signup.
    // • Only the owner or admin can read/update it.
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── opportunities ─────────────────────────────────────────────────────────
    // • All authenticated users can read opportunities.
    // • Only the owning startup (companyId == uid) can create/update/delete.
    // • Admin can do anything.
    match /opportunities/{oppId} {
      allow read:   if isAuth();
      allow create: if isApprovedStartup() &&
                       request.resource.data.companyId == request.auth.uid;
      allow update: if isAdmin() ||
                       (isApprovedStartup() &&
                        resource.data.companyId == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isApprovedStartup() &&
                        resource.data.companyId == request.auth.uid);
    }

    // ── applications ──────────────────────────────────────────────────────────
    // • A student can create an application (studentId must equal their uid).
    // • The student who applied OR the startup who owns the opportunity can read.
    // • Only the startup (companyId == uid) or admin can update status.
    match /applications/{appId} {
      allow create: if isAuth() &&
                       request.resource.data.studentId == request.auth.uid;
      allow read:   if isAuth() &&
                       (resource.data.studentId == request.auth.uid ||
                        resource.data.companyId == request.auth.uid ||
                        isAdmin());
      allow update: if isAdmin() ||
                       (isAuth() && resource.data.companyId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── conversations ─────────────────────────────────────────────────────────
    // • Only participants can read/write conversation metadata.
    match /conversations/{convoId} {
      allow read, write: if isAuth() &&
                            request.auth.uid in resource.data.participants;
      allow create:      if isAuth() &&
                            request.auth.uid in request.resource.data.participants;

      // ── messages sub-collection ───────────────────────────────────────────
      // • Only participants of the parent conversation can read/write messages.
      match /messages/{msgId} {
        allow read, write: if isAuth() &&
                              request.auth.uid in
                              get(/databases/$(database)/documents/conversations/$(convoId)).data.participants;
      }
    }

    // ── Default deny all ─────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
